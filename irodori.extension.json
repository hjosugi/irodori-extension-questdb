{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.questdb",
  "name": "QuestDB Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "QuestDB Connector contributes the QuestDB database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-questdb",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "questdb.connector",
        "engine": "questdb",
        "label": "QuestDB",
        "aliases": [
          "questdb",
          "QuestDB"
        ],
        "defaultPort": 8812,
        "wire": "postgres",
        "module": "questdb.driver",
        "features": [
          "metadata",
          "sql",
          "streaming",
          "timeSeries",
          "timeBuckets",
          "latestValue",
          "queryTemplates",
          "visualization",
          "asOfJoin"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "questdb",
            "wire": "postgres",
            "port": 8812,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 8812,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 8812
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 8812
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "userPassword",
              "label": "User/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "restToken",
              "label": "REST / ILP token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "postgres",
            "questdb"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "timeSeries"
          ],
          "inspiredBy": [
            "QuestDB Web Console",
            "SAMPLE BY",
            "LATEST ON",
            "ASOF JOIN"
          ],
          "resultViews": [
            "timeChart",
            "table",
            "heatmap"
          ],
          "objectTypes": [
            "tables",
            "designatedTimestamps",
            "symbols",
            "partitions",
            "walTables"
          ],
          "workflows": [
            {
              "id": "time-sample-by",
              "label": "Sample by window",
              "description": "Aggregate timestamped rows into fixed windows.",
              "resultView": "timeChart",
              "templateIds": [
                "time-questdb-sample-by"
              ]
            },
            {
              "id": "time-latest",
              "label": "Latest per key",
              "description": "Read the newest row per symbol or device.",
              "resultView": "table",
              "templateIds": [
                "time-questdb-latest"
              ]
            },
            {
              "id": "time-asof-join",
              "label": "As-of join",
              "description": "Join event streams by nearest preceding timestamp.",
              "resultView": "table",
              "templateIds": [
                "time-questdb-asof-join"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "time-questdb-sample-by",
              "label": "SAMPLE BY aggregate",
              "language": "sql",
              "description": "Downsample recent readings into one-minute buckets.",
              "insertText": "SELECT timestamp, avg(value)\nFROM readings\nWHERE timestamp >= dateadd('h', -1, now())\nSAMPLE BY 1m ALIGN TO CALENDAR;",
              "parameters": [],
              "resultView": "timeChart"
            },
            {
              "id": "time-questdb-latest",
              "label": "LATEST ON per key",
              "language": "sql",
              "description": "Return the latest row for each sensor.",
              "insertText": "SELECT *\nFROM readings\nLATEST ON timestamp PARTITION BY sensor_id;",
              "parameters": [],
              "resultView": "table"
            },
            {
              "id": "time-questdb-asof-join",
              "label": "ASOF JOIN",
              "language": "sql",
              "description": "Join two time-aligned event streams.",
              "insertText": "SELECT *\nFROM trades t ASOF JOIN quotes q ON (symbol)\nWHERE t.timestamp >= dateadd('d', -1, now());",
              "parameters": [],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "time-designated",
              "label": "Designated timestamp",
              "description": "Highlight the designated timestamp column and partitioning choice."
            },
            {
              "id": "time-symbol",
              "label": "Symbol columns",
              "description": "Show symbol columns as preferred group and partition keys."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "questdb.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
